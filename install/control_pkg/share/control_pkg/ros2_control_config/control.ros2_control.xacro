            </command_interface>

            <command_interface name="velocity">
            <param name="min">-10</param>
            <param name="max">10</param>
            </command_interface>

            <command_interface name="effort">
            <param name="min">-10</param>
            <param name="max">10</param>
            </command_interface>
            
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="bl_hip_joint">

            <command_interface name="position">
            <param name="min">-1.05</param>
            <param name="max">1.05</param>
            </command_interface>

            <command_interface name="velocity">
            <param name="min">-10</param>
            <param name="max">10</param>
            </command_interface>

            <command_interface name="effort">
            <param name="min">-10</param>
            <param name="max">10</param>
            </command_interface>
            
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="bl_knee_joint">

            <command_interface name="position">
            <param name="min">-0.7</param>
            <param name="max">1.4</param>
            </command_interface>

            <command_interface name="velocity">
            <param name="min">-10</param>
            <param name="max">10</param>
            </command_interface>

            <command_interface name="effort">
            <param name="min">-10</param>
            <param name="max">10</param>
            </command_interface>
            
            <state_interface name="position"/>
            <state_interface name="velocity"/>
            <state_interface name="effort"/>
        </joint>

        <joint name="bl_thigh_joint">

            <command_interface name="position">
